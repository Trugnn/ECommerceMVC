@model ECommerceMVC.ViewModels.LoginVM
@{
    ViewData["Title"] = "Login";
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4 mt-5 pt-4">Đăng nhập</h1>
        <form asp-action="Login" asp-controller="KhachHang" method="post" asp-route-returnurl="@ViewBag.ReturnUrl">
            <div class="text-danger" asp-validation-summary="All"></div>
            <div class="row">
                <div class="col-md-12 col-lg-6">
                    <div class="form-item w-100">
                        <label asp-for="UserName" class="form-label my-3"></label><sup>*</sup>
                        <input asp-for="UserName" class="form-control form-control-lg">
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-12 col-lg-6">
                    <div class="form-item w-100">
                        <label asp-for="Password" class="form-label my-3"></label><sup>*</sup>
                        <input asp-for="Password" class="form-control form-control-lg">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row g-4 justify-content-center pt-4">
                <div class="col-md-8 col-lg-6">
                    <button type="submit" class="btn border-secondary py-2 px-3 w-100 text-primary">Đăng nhập
                    </button>
                    <a asp-controller="KhachHang" asp-action="ForgotPassword" class="btn btn-outline-danger py-2 px-3 my-2 w-100">Quên mật khẩu</a>
                </div>
            </div>
        </form>
    </div>
</div>

