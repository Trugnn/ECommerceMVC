@model ECommerceMVC.ViewModels.RegisterVM

@{
    ViewData["Title"] = "Register";
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4 mt-5 pt-4">Register</h1>
        <form asp-action="Register" asp-controller="KhachHang" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="form-item w-100">
                    <label asp-for="@Model.MaKh" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.MaKh" class="form-control">
                    <span asp-validation-for="@Model.MaKh" class="text-danger"></span>
                </div>
                <div class="form-item w-100">
                    <label asp-for="@Model.MatKhau" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.MatKhau" class="form-control">
                    <span asp-validation-for="@Model.MatKhau" class="text-danger"></span>
                </div>
                <div class="form-item w-100">
                    <label asp-for="@Model.XacNhanMatKhau" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.XacNhanMatKhau" class="form-control">
                    <span asp-validation-for="@Model.XacNhanMatKhau" class="text-danger"></span>
                </div>
                <div class="form-item">
                    <label asp-for="@Model.HoTen" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.HoTen" class="form-control"/>
                    <span asp-validation-for="@Model.HoTen" class="text-danger"></span>
                </div>
                <div class="col-md-12">
                    <div class="form-item w-100 mb-4">
                        <label class="form-label my-3">Giới tính</label>
                        <div class="d-flex mt-2">

                            <div class="form-check me-4">
                                <input type="radio" asp-for="GioiTinh" id="GioiTinhNam" value="True" class="form-check-input">
                                <label class="form-check-label" for="GioiTinhNam">Nam</label>
                            </div>

                            <div class="form-check">
                                <input type="radio" asp-for="GioiTinh" id="GioiTinhNu" value="False" class="form-check-input">
                                <label class="form-check-label" for="GioiTinhNu">Nữ</label>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="form-item">
                    <label asp-for="@Model.NgaySinh" class="form-label my-3"></label>
                    <input asp-for="@Model.NgaySinh" class="form-control" />
                    <span asp-validation-for="@Model.NgaySinh" class="text-danger"></span>
                </div>
                <div class="form-item">
                    <label asp-for="@Model.DiaChi" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.DiaChi" class="form-control" />
                    <span asp-validation-for="@Model.DiaChi" class="text-danger"></span>
                </div>
                <div class="form-item">
                    <label asp-for="@Model.DienThoai" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.DienThoai" class="form-control" />
                    <span asp-validation-for="@Model.DienThoai" class="text-danger"></span>
                </div>
                <div class="form-item">
                    <label asp-for="@Model.Email" class="form-label my-3"></label><sup>*</sup>
                    <input asp-for="@Model.Email" class="form-control" />
                    <span asp-validation-for="@Model.Email" class="text-danger"></span>
                </div>
                <div class="form-item">
                    <label for="Hinh" class="form-label my-3">Hình<sup>*</sup></label>
                    <input type="file" name="Hinh" class="form-control" />
                </div>
            </div>
            <div class="row g-4 justify-content-center pt-4">
                <div class="col-md-8 col-lg-6">
                    <button type="submit" class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary">Đăng ký</button>
                </div>
            </div>
        </form>
    </div>
</div>