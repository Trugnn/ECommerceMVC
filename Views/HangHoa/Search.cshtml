@model IEnumerable<ECommerceMVC.ViewModels.HangHoaVM>
@{
    ViewData["Title"] = "Search";
    Layout = "_DanhSachHangHoa";
}

@* Hiển thị số lượng sản phẩm *@
<div class="search-results-header mb-4 pb-2 border-bottom border-success">

    <h2 class="display-5 fw-bold text-dark d-inline-block mb-0">Search</h2>

    <span class="ms-3 fs-5 fw-normal text-secondary">
        (Có <b>@Model.Count()</b> sản phẩm)
    </span>

</div>

@await Html.PartialAsync("ProductItem", Model)

